  "logic": {
    "selectionAlgorithm": {
      "step1": "A user 1-3 belépő chipet választ az entry képernyőn.",
      "step2": "A kiválasztott entry optionök mapsTo mezőiből összesített tag-score készül.",
      "step3": "A legmagasabb score-ú pathway indul el. Holtverseny esetén a priority dönt.",
      "step4": "Az adott pathway 2-3 kérdése fut le.",
      "step5": "Minden válasz domain score-okat növel.",
      "step6": "A belépő tagsúlyok és a kérdésválasz-score-ok összeadódnak.",
      "step7": "Elsődleges eredmény = legmagasabb domain.",
      "step8": "Másodlagos eredmény = második legmagasabb domain, ha score-ja legalább az első 60%-a. Ha nem, akkor secondary elrejthető.",
      "step9": "Termékajánlás: primary domain productjai + secondary domain első 1-2 terméke, de duplikáció nélkül.",
      "step10": "Ha a felhasználó 3 különböző irányt jelölt belépéskor, akkor a secondary mindenképp jelenjen meg, ha a score legalább 40%."
    },
    "limits": {
      "absoluteQuestionCap": 5,
      "entryCountsAsQuestion": true,
      "defaultFollowupCount": 3,
      "maxFollowupCount": 4
    },
    "fallbackRules": [
      "Ha a pathway végén túl sok domain kap hasonló score-t, az app egy 'összetett mintázat' eredményt mutathat, és 2 domain kombinált terméklistáját adja.",
      "Ha a user csak egy nagyon szűk témát választott, secondary result opcionális.",
      "Ha a user újraindítja a kitöltést, minden score nullázódjon."
    ],
    "resultTypes": [
      "energy",
      "mind",
      "sleep",
      "hydration",
